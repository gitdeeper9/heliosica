# HELIOSICA Environment Variables Example
# Heliospheric Event and L1 Integrated Observatory for Solar Intelligence and Coronal Activity
# Version: 1.0.0 | DOI: 10.5281/zenodo.19042948

# ============================================
# Application Settings
# ============================================
HELIOSICA_ENV=development
HELIOSICA_DEBUG=true
HELIOSICA_SECRET_KEY=your-secret-key-here-change-in-production
HELIOSICA_LOG_LEVEL=INFO

# ============================================
# Database Configuration
# ============================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=heliosica
DB_USER=heliosica_user
DB_PASSWORD=changeme
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# ============================================
# Redis Configuration (for caching)
# ============================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_CACHE_TTL=3600

# ============================================
# API Configuration
# ============================================
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
API_RATE_LIMIT=100
API_KEY=your-api-key-here

# ============================================
# Data Sources
# ============================================
SOHO_DATA_PATH=/data/raw/soho
DSCOVR_DATA_PATH=/data/raw/dscovr
ACE_DATA_PATH=/data/raw/ace
OMNI_DATA_PATH=/data/raw/omni
NOAA_KP_PATH=/data/raw/noaa_kp
NMDB_PATH=/data/raw/nmdb

# ============================================
# External API Keys
# ============================================
NOAA_API_KEY=
NASA_API_KEY=
ESA_API_KEY=

# ============================================
# SPIN Parameters Defaults
# ============================================
DBM_GAMMA_DEFAULT=2.0e-7
DBM_VSW_DEFAULT=450
DBM_NP_DEFAULT=5.0

# ============================================
# Deployment
# ============================================
NETLIFY_SITE_ID=heliosica
NETLIFY_AUTH_TOKEN=your-netlify-auth-token
PYPI_TOKEN=your-pypi-token
DOCKER_REGISTRY=docker.io
DOCKER_USERNAME=your-docker-username
DOCKER_PASSWORD=your-docker-password

# ============================================
# Monitoring
# ============================================
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090
GRAFANA_PASSWORD=admin
SENTRY_DSN=

# ============================================
# Email Configuration (for alerts)
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
ALERT_EMAIL=admin@heliosica.netlify.app

# ============================================
# Security
# ============================================
JWT_SECRET_KEY=your-jwt-secret-key-here
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24
CORS_ORIGINS=["http://localhost:5000", "https://heliosica.netlify.app"]

# ============================================
# Performance Tuning
# ============================================
NUM_CORES=4
CHUNK_SIZE=1000
CACHE_ENABLED=true
PARALLEL_PROCESSING=true

# ============================================
# Paths
# ============================================
DATA_DIR=/data
OUTPUT_DIR=/output
LOG_DIR=/logs
CONFIG_DIR=/config
MODELS_DIR=/models

# ============================================
# IMPORTANT NOTES
# ============================================
# 1. NEVER commit this file to version control!
# 2. Copy to .env for local development
# 3. Use strong passwords in production
# 4. Rotate secrets regularly
# 5. Use secrets management in production
